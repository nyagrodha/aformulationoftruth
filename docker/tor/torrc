# Tor configuration for A Formulation of Truth

# Hidden Service for the main application routed through Caddy on the host
HiddenServiceDir /etc/tor/hidden_service
HiddenServicePort 80 192.168.1.100:8080

# Control settings
ControlPort 9051
HashedControlPassword 16:872860B76453A77D60CA2BB8C1A7042072093276A3D701AD684053EC4C

# Performance tuning
NumCPUs 2
RelayBandwidthRate 1 MB
RelayBandwidthBurst 2 MB

# Disable exit traffic
ExitPolicy reject *:*

# Logging
Log notice stdout

# Circuit behaviour
NewCircuitPeriod 60
MaxCircuitDirtiness 300

# Run Tor under its non-privileged account and pin data directories
User tor
DataDirectory /etc/tor/data
