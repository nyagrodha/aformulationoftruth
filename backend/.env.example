# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/aformulationoftruth

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-here

# Admin Configuration
ADMIN_EMAIL=your-email@example.com

# IP Geolocation Configuration (ipinfo.io)
# Get your token from https://ipinfo.io/signup
# Free tier: 50,000 requests/month (no privacy detection)
# Paid tiers: Include VPN/Tor/Proxy detection
IPINFO_TOKEN=your-ipinfo-token-here

# Keybase Bot Configuration
KEYBASE_USERNAME=your_bot_username
KEYBASE_PAPER_KEY=your_keybase_paper_key_here

# Server Configuration
PORT=3000
NODE_ENV=production